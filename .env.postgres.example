# ZGAI PostgreSQL 试用环境示例。请在终端导出变量，不要提交真实密码。
ZGAI_DB=postgres
POSTGRES_URL=jdbc:postgresql://localhost:5432/zgai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=zgai
POSTGRES_USER=zgai
POSTGRES_PASSWORD=请改为数据库强密码
# 仅离线迁移 execute 使用，必须与 POSTGRES_URL 中的目标库名完全一致。
MIGRATION_CONFIRM_DATABASE=
PG_BIN=/opt/homebrew/opt/postgresql@16/bin
PG_DUMP_PATH=/opt/homebrew/opt/postgresql@16/bin/pg_dump
INITIAL_ADMIN_PASSWORD=请改为仅管理员知悉的强密码
JWT_SECRET=请使用至少32字节的随机字符串
CRYPTO_SECRET_KEY=请使用独立的强随机字符串
YUANDIAN_API_KEY=
LM_STUDIO_BASE_URL=http://192.168.1.200:1234/v1
LM_STUDIO_MODEL=qwen/qwen3.6-35b-a3b
LM_STUDIO_API_KEY=
LM_STUDIO_MAX_CONCURRENT=1
LM_STUDIO_QUEUE_WAIT_SECONDS=600
LM_STUDIO_RETRY_COUNT=1
LM_STUDIO_RETRY_DELAY_MILLIS=1500
LM_STUDIO_CURL_FALLBACK_ENABLED=true
AI_EMBEDDING_PROVIDER=LM_STUDIO
AI_EMBEDDING_BASE_URL=http://192.168.1.200:1234/v1
AI_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
AI_EMBEDDING_DIMENSION=768
AI_EMBEDDING_API_KEY=
QDRANT_ENABLED=true
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=lawfirm-knowledge
QDRANT_VECTOR_SIZE=768
SEED_DEMO_DATA=false
EMPLOYEE_SYNC_ENABLED=false
CASE_FILE_LIBRARY_ROOT=/data/case-files
ARCHIVE_WORKER_BASE_URL=http://archive-worker:8091
ARCHIVE_WORKER_TOKEN=请使用独立的内部服务强令牌
ARCHIVE_WORKER_TIMEOUT_SECONDS=1800
ARCHIVE_ALLOWED_ROOTS=/data/case-files
ARCHIVE_OCR_CACHE=/data/archive-cache
ARCHIVE_CJK_FONT=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc
