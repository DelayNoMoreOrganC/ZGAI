# Copy to .env.cloud and chmod 600. Never commit the real file.
CLOUD_DEPLOYMENT_MODE=DETACHED_DEMO

POSTGRES_IMAGE=postgres:16-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.12.0
POSTGRES_DB=zgai
POSTGRES_USER=zgai
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
INITIAL_ADMIN_PASSWORD=CHANGE_ME_INITIAL_ADMIN_PASSWORD
JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_BYTES
CRYPTO_SECRET_KEY=CHANGE_ME_DIFFERENT_32_RANDOM_BYTES

# Containers bind to loopback. Host Nginx terminates HTTPS.
ZGAI_LISTEN_ADDRESS=127.0.0.1
ZGAI_HTTP_PORT=3017
ZGAI_DOMAIN=demo.example.com

ZGAI_POSTGRES_DATA=/srv/zgai/postgres
ZGAI_QDRANT_DATA=/srv/zgai/qdrant
ZGAI_CASE_FILES=/srv/zgai/files/case-files
ZGAI_KNOWLEDGE_FILES=/srv/zgai/files/knowledge-files
ZGAI_BACKUPS=/srv/zgai/backups
ZGAI_KNOWLEDGE_IMPORTS=/srv/zgai/knowledge-imports
ZGAI_DOCUMENT_INTAKE=/srv/zgai/document-intake
ZGAI_APPROVAL_FILES=/srv/zgai/files/approval-files
ZGAI_FIRM_POLICY_SOURCE=/srv/zgai/firm-policies
BACKUP_RETENTION_DAYS=180

# HYBRID_VPN only: case files, knowledge files and firm policies live under the
# VPN-mounted NAS root. PostgreSQL, Qdrant and the primary backup stay on cloud SSD.
ZGAI_NAS_MOUNT_ROOT=
ZGAI_OFFSITE_BACKUP_ROOT=
VPN_HEALTHCHECK_HOST=

# Leave empty for a detached, retrieval-only demo. In HYBRID_VPN use a private
# VPN address; never expose LM Studio port 1234 to the public Internet.
LM_STUDIO_BASE_URL=
LM_STUDIO_MODEL=
LM_STUDIO_API_KEY=
AI_EMBEDDING_PROVIDER=DISABLED
AI_EMBEDDING_BASE_URL=
AI_EMBEDDING_MODEL=
AI_EMBEDDING_DIMENSION=768
AI_EMBEDDING_API_KEY=
QDRANT_ENABLED=true
QDRANT_COLLECTION_NAME=lawfirm-knowledge
YUANDIAN_API_KEY=
