# Copy to .env.demo. The real file is ignored by Git.
POSTGRES_IMAGE=postgres:16-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.12.0
POSTGRES_DB=zgai
POSTGRES_USER=zgai
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
POSTGRES_PORT=5432

INITIAL_ADMIN_PASSWORD=CHANGE_ME_INITIAL_ADMIN_PASSWORD
JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_BYTES
CRYPTO_SECRET_KEY=CHANGE_ME_DIFFERENT_32_RANDOM_BYTES

CASE_FILE_LIBRARY_ROOT=/Volumes/ZGAI/case-files
KNOWLEDGE_FILE_LIBRARY_ROOT=/Volumes/ZGAI/knowledge-files
BACKUP_ROOT_PATH=/Volumes/ZGAI/backups
FIRM_POLICY_SOURCE_ROOT=/Volumes/律所共享资料/律所制度、章程

QDRANT_ENABLED=true
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=lawfirm-knowledge

LM_STUDIO_BASE_URL=http://192.168.1.200:1234/v1
LM_STUDIO_MODEL=qwen/qwen3.6-35b-a3b
LM_STUDIO_API_KEY=
AI_EMBEDDING_PROVIDER=LM_STUDIO
AI_EMBEDDING_BASE_URL=http://192.168.1.200:1234/v1
AI_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
AI_EMBEDDING_DIMENSION=768
AI_EMBEDDING_API_KEY=
