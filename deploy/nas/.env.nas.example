# Copy to .env.nas on the NAS. Never commit the real file.
POSTGRES_IMAGE=postgres:16-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.12.0
POSTGRES_DB=zgai
POSTGRES_USER=zgai
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
INITIAL_ADMIN_PASSWORD=CHANGE_ME_INITIAL_ADMIN_PASSWORD
JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_BYTES
CRYPTO_SECRET_KEY=CHANGE_ME_DIFFERENT_32_RANDOM_BYTES
ARCHIVE_WORKER_TOKEN=CHANGE_ME_DIFFERENT_INTERNAL_ARCHIVE_TOKEN

ZGAI_LISTEN_ADDRESS=0.0.0.0
ZGAI_HTTP_PORT=3017

# Use absolute NAS-local paths. PostgreSQL and Qdrant must be on SSD storage.
ZGAI_POSTGRES_DATA=/volume1/docker/zgai/postgres
ZGAI_QDRANT_DATA=/volume1/docker/zgai/qdrant
ZGAI_CASE_FILES=/volume1/ZGAI/case-files
ZGAI_KNOWLEDGE_FILES=/volume1/ZGAI/knowledge-files
ZGAI_BACKUPS=/volume1/ZGAI/backups
ZGAI_KNOWLEDGE_IMPORTS=/volume1/ZGAI/knowledge-imports
ZGAI_DOCUMENT_INTAKE=/volume1/ZGAI/document-intake
ZGAI_APPROVAL_FILES=/volume1/ZGAI/approval-files
ZGAI_ARCHIVE_CACHE=/volume1/docker/zgai/archive-cache
ZGAI_FIRM_POLICY_SOURCE=/volume1/律所共享资料/律所制度、章程
BACKUP_RETENTION_DAYS=180

LM_STUDIO_BASE_URL=http://192.168.1.200:1234/v1
LM_STUDIO_MODEL=
LM_STUDIO_API_KEY=
ARCHIVE_WORKER_TIMEOUT_SECONDS=1800
AI_EMBEDDING_PROVIDER=LM_STUDIO
AI_EMBEDDING_BASE_URL=http://192.168.1.200:1234/v1
AI_EMBEDDING_MODEL=
AI_EMBEDDING_DIMENSION=1024
AI_EMBEDDING_API_KEY=
QDRANT_ENABLED=true
QDRANT_COLLECTION_NAME=lawfirm-knowledge
YUANDIAN_API_KEY=
